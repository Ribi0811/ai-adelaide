"use client";

import { useEffect, useState } from "react";
import Link from "next/link";
import { AnimatePresence, motion, useReducedMotion } from "framer-motion";

const workflowPresets = [
  {
    id: "lead-capture",
    tab: "Lead Capture",
    title: "Lead Capture Automation",
    rows: [
      ["Missed call detected", "0s", "bg-electric/70"],
      ["SMS reply sent", "14s", "bg-accent/80"],
      ["Lead qualified", "28s", "bg-electric/70"],
      ["Booking link delivered", "41s", "bg-accent/80"],
    ] as const,
    leftCard: {
      title: "AI Assistant",
      body: "Answers after-hours enquiries and routes urgent jobs.",
      progress: 83,
    },
    rightCard: {
      title: "Ops Feed",
      items: [
        "Review request sent after completed job",
        "Invoice reminder queued for tomorrow 9:00 AM",
        "New lead tagged: Emergency plumbing",
      ],
    },
  },
  {
    id: "bookkeeping",
    tab: "Bookkeeping Prep",
    title: "Bookkeeping Prep Automation",
    rows: [
      ["Bank feed imported", "0m", "bg-electric/70"],
      ["Transactions categorised", "2m", "bg-accent/80"],
      ["Exceptions flagged", "4m", "bg-electric/70"],
      ["Accountant summary exported", "6m", "bg-accent/80"],
    ] as const,
    leftCard: {
      title: "AI Categoriser",
      body: "Sorts transactions, flags odd items, and keeps your books cleaner before handoff.",
      progress: 91,
    },
    rightCard: {
      title: "Ops Feed",
      items: [
        "3 uncategorised transactions flagged for review",
        "Materials spend grouped under supplier category",
        "Weekly summary prepared for accountant handoff",
      ],
    },
  },
  {
    id: "reviews-followup",
    tab: "Reviews + Follow-up",
    title: "Reviews + Follow-up Automation",
    rows: [
      ["Job marked complete", "0m", "bg-electric/70"],
      ["Review request sent", "1m", "bg-accent/80"],
      ["Customer clicked link", "9m", "bg-electric/70"],
      ["Follow-up reminder queued", "24h", "bg-accent/80"],
    ] as const,
    leftCard: {
      title: "Follow-up Engine",
      body: "Sends review requests and nudges customers without your team chasing manually.",
      progress: 88,
    },
    rightCard: {
      title: "Ops Feed",
      items: [
        "Google review request delivered to completed job",
        "No response after 48h: reminder scheduled",
        "Positive review received and logged to CRM",
      ],
    },
  },
];

export default function Hero() {
  const prefersReducedMotion = useReducedMotion();
  const [activeIndex, setActiveIndex] = useState(0);
  const [isPaused, setIsPaused] = useState(false);
  const activeWorkflow = workflowPresets[activeIndex];

  useEffect(() => {
    if (isPaused) return;

    const timer = window.setInterval(() => {
      setActiveIndex((current) => (current + 1) % workflowPresets.length);
    }, 5000);

    return () => window.clearInterval(timer);
  }, [isPaused]);

  return (
    <section className="section-shell relative min-h-screen overflow-hidden pt-28 md:pt-32">
      <div className="pointer-events-none absolute inset-0">
        <div className="absolute left-[-12%] top-12 h-72 w-72 rounded-full bg-electric/20 blur-3xl" />
        <div className="absolute right-[-8%] top-24 h-80 w-80 rounded-full bg-accent/15 blur-3xl" />
        <div className="absolute left-1/2 top-1/3 h-[420px] w-[420px] -translate-x-1/2 rounded-full bg-accent/5 blur-3xl" />
      </div>

      <div className="max-w-container mx-auto grid gap-10 px-6 pb-16 md:min-h-[calc(100vh-8rem)] md:grid-cols-[1.05fr_0.95fr] md:items-center">
        <div className="relative">
          <motion.div
            initial={{ opacity: 0, y: 12 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.55 }}
            className="eyebrow mb-6"
          >
            AI Automation Adelaide — Built for Small Business
          </motion.div>

          <motion.h1
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6, delay: 0.05 }}
            className="mb-6 max-w-3xl text-h1-mobile text-textPrimary md:text-h1"
          >
            Stop Losing Leads
            <span className="block bg-gradient-to-r from-textPrimary via-accent to-electric bg-clip-text text-transparent">
              While You Sleep
            </span>
          </motion.h1>

          <motion.p
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6, delay: 0.12 }}
            className="max-w-2xl text-body-mobile text-textSecondary md:text-body"
          >
            Your phone rings. You miss it. They call your competitor. We build
            AI-powered follow-up and admin workflows for Adelaide service
            businesses that respond, qualify, and book instantly so you wake up
            to booked jobs, not missed opportunities.
          </motion.p>

          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6, delay: 0.2 }}
            className="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap"
          >
            <Link href="/contact" className="btn-primary px-8 py-4">
              Book Free 15-Min Chat
              <span aria-hidden>→</span>
            </Link>
            <a href="#how-it-works" className="btn-secondary px-8 py-4">
              See How It Works
              <span aria-hidden>↓</span>
            </a>
          </motion.div>
          <motion.p
            initial={{ opacity: 0, y: 12 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5, delay: 0.24 }}
            className="mt-3 text-sm text-textSecondary"
          >
            Start with the <span className="font-semibold text-textPrimary">$247 Efficiency Audit</span> if you want clarity before committing.
          </motion.p>

          <motion.div
            initial={{ opacity: 0, y: 12 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6, delay: 0.28 }}
            className="mt-8 grid gap-3 sm:grid-cols-3"
          >
            <div className="metric-card scan-line">
              <p className="font-mono text-[11px] uppercase tracking-[0.16em] text-textSecondary">
                Response Time
              </p>
              <p className="mt-2 text-2xl font-semibold text-textPrimary">&lt; 60s</p>
              <p className="mt-1 text-sm text-textSecondary">after missed calls</p>
            </div>
            <div className="metric-card">
              <p className="font-mono text-[11px] uppercase tracking-[0.16em] text-textSecondary">
                Setup Window
              </p>
              <p className="mt-2 text-2xl font-semibold text-textPrimary">2-5 days</p>
              <p className="mt-1 text-sm text-textSecondary">typical go-live</p>
            </div>
            <div className="metric-card">
              <p className="font-mono text-[11px] uppercase tracking-[0.16em] text-textSecondary">
                Outcome
              </p>
              <p className="mt-2 text-2xl font-semibold text-textPrimary">More jobs</p>
              <p className="mt-1 text-sm text-textSecondary">fewer admin hours</p>
            </div>
          </motion.div>
        </div>

        <motion.div
          initial={{ opacity: 0, x: 18 }}
          animate={{ opacity: 1, x: 0 }}
          transition={{ duration: 0.65, delay: 0.15 }}
          className="relative"
        >
          <div
            className="panel grid-overlay relative overflow-hidden p-5 md:p-6"
            onMouseEnter={() => setIsPaused(true)}
            onMouseLeave={() => setIsPaused(false)}
          >
            <div className="absolute inset-0 bg-gradient-to-br from-electric/8 via-transparent to-accent/10" />
            <div className="relative">
              <div className="mb-4 flex flex-wrap gap-2">
                {workflowPresets.map((workflow, index) => (
                  <button
                    key={workflow.id}
                    type="button"
                    onClick={() => setActiveIndex(index)}
                    onFocus={() => setIsPaused(true)}
                    onBlur={() => setIsPaused(false)}
                    className={`rounded-full border px-3 py-2 font-mono text-[11px] uppercase tracking-[0.14em] transition ${
                      index === activeIndex
                        ? "border-accent/30 bg-accent/10 text-accent"
                        : "border-slate-200/80 bg-white/80 text-textSecondary hover:border-slate-300"
                    }`}
                    aria-pressed={index === activeIndex}
                  >
                    {workflow.tab}
                  </button>
                ))}
              </div>

              <AnimatePresence mode="wait">
                <motion.div
                  key={activeWorkflow.id}
                  initial={{ opacity: 0, y: 8 }}
                  animate={{ opacity: 1, y: 0 }}
                  exit={{ opacity: 0, y: -8 }}
                  transition={{ duration: 0.28 }}
                >
                  <div className="relative flex items-center justify-between rounded-2xl border border-slate-200/80 bg-white/90 px-4 py-3">
                    <div>
                      <p className="font-mono text-[11px] uppercase tracking-[0.18em] text-textSecondary">
                        Workflow Status
                      </p>
                      <p className="mt-1 text-sm font-semibold text-textPrimary">
                        {activeWorkflow.title}
                      </p>
                    </div>
                    <span className="rounded-full border border-accent/25 bg-accent/10 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.16em] text-accent">
                      Live
                    </span>
                  </div>

                  <div className="mt-4 space-y-3">
                    {activeWorkflow.rows.map(([label, time, dot], index) => (
                      <motion.div
                        key={`${activeWorkflow.id}-${label}`}
                        initial={{ opacity: 0, y: 10 }}
                        animate={{ opacity: 1, y: 0 }}
                        transition={{ duration: 0.25, delay: index * 0.04 }}
                        className="panel-soft flex items-center justify-between gap-3 px-4 py-3"
                      >
                        <div className="min-w-0 flex items-center gap-3">
                          <span className={`h-2.5 w-2.5 rounded-full ${dot}`} />
                          <span className="truncate text-sm text-textPrimary">{label}</span>
                        </div>
                        <span className="font-mono text-xs text-textSecondary">{time}</span>
                      </motion.div>
                    ))}
                  </div>

                  <div className="mt-4 grid gap-3 sm:grid-cols-2">
                    <motion.div
                      animate={prefersReducedMotion ? undefined : { y: [0, -8, 0] }}
                      transition={
                        prefersReducedMotion
                          ? undefined
                          : { duration: 5.2, repeat: Infinity, ease: "easeInOut" }
                      }
                      className="panel-soft p-4"
                    >
                      <p className="font-mono text-[11px] uppercase tracking-[0.16em] text-textSecondary">
                        {activeWorkflow.leftCard.title}
                      </p>
                      <p className="mt-2 text-sm text-textPrimary">
                        {activeWorkflow.leftCard.body}
                      </p>
                      <div className="mt-4 h-2 rounded-full bg-slate-200">
                        <div
                          className="h-2 rounded-full bg-gradient-to-r from-accent to-electric"
                          style={{ width: `${activeWorkflow.leftCard.progress}%` }}
                        />
                      </div>
                    </motion.div>

                    <motion.div
                      animate={prefersReducedMotion ? undefined : { y: [0, -10, 0] }}
                      transition={
                        prefersReducedMotion
                          ? undefined
                          : {
                              duration: 6.1,
                              repeat: Infinity,
                              ease: "easeInOut",
                              delay: 0.4,
                            }
                      }
                      className="panel-soft p-4"
                    >
                      <p className="font-mono text-[11px] uppercase tracking-[0.16em] text-textSecondary">
                        {activeWorkflow.rightCard.title}
                      </p>
                      <div className="mt-3 space-y-2 text-xs text-textSecondary">
                        {activeWorkflow.rightCard.items.map((item) => (
                          <p
                            key={`${activeWorkflow.id}-${item}`}
                            className="rounded-lg border border-slate-200/80 bg-white/90 px-2 py-1"
                          >
                            {item}
                          </p>
                        ))}
                      </div>
                    </motion.div>
                  </div>
                </motion.div>
              </AnimatePresence>
            </div>
          </div>
        </motion.div>
      </div>
    </section>
  );
}
